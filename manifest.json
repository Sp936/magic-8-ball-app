<!DOCTYPE html>
<html>
<head>
  <title>Magic Dopamine Ball ✨</title>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- ✧ PWA -->
  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#7c3aed">
  <meta name="mobile-web-app-capable" content="yes">

  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI';
      background: radial-gradient(circle at top,#140033,#000);
      color: #fff;
      text-align: center;
    }

    /* ✧ HEADER BALL */
    .header-ball {
      width: 120px;
      height: 120px;
      margin: 20px auto 10px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #222, #000);
      box-shadow:
        inset -10px -10px 20px rgba(0,0,0,0.9),
        inset 5px 5px 10px rgba(255,255,255,0.1),
        0 0 40px rgba(124,58,237,0.8);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header-inner {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg,#6366f1,#c084fc);
      transform: rotate(45deg);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header-inner span {
      transform: rotate(-45deg);
      font-weight: bold;
    }

    h1 {
      font-size: 1.8rem;
      margin-bottom: 10px;
    }

    input, select {
      width: 85%;
      max-width: 400px;
      padding: 14px;
      margin: 8px;
      border-radius: 14px;
      border: none;
      background: rgba(255,255,255,0.1);
      color: #fff;
    }

    button {
      padding: 14px;
      border-radius: 14px;
      border: none;
      background: linear-gradient(135deg,#7c3aed,#ec4899);
      color: white;
      margin: 6px;
    }

    /* ✧ MAIN BALL */
    .ball {
      width: 240px;
      height: 240px;
      margin: 20px auto;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%,#1a1a1a,#000);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 80px rgba(124,58,237,0.9);
    }

    .inner {
      width: 120px;
      height: 120px;
      background: linear-gradient(135deg,#6366f1,#c084fc);
      transform: rotate(45deg);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #result {
      transform: rotate(-45deg);
      font-weight: bold;
    }

    /* ✧ INSTRUCTIONS */
    .instructions {
      width: 85%;
      max-width: 400px;
      background: rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 10px;
      margin: 10px auto;
      cursor: pointer;
    }

    .instructions p {
      display: none;
      text-align: left;
      font-size: 0.9rem;
    }

    .instructions.active p {
      display: block;
    }

    /* ✧ DRAWER */
    .drawer {
      position: fixed;
      bottom: 0;
      width: 100%;
      background: #111;
      border-radius: 20px 20px 0 0;
      padding: 15px;
      transform: translateY(75%);
      transition: 0.3s;
    }

    .drawer.open {
      transform: translateY(0);
    }

    li {
      display: flex;
      justify-content: space-between;
      margin: 6px;
      background: #222;
      padding: 10px;
      border-radius: 10px;
    }

  </style>
</head>

<body>

<!-- ✧ HEADER -->
<div class="header-ball">
  <div class="header-inner">
    <span>8</span>
  </div>
</div>

<h1>Magic Dopamine Ball</h1>

<!-- ✧ INSTRUCTIONS -->
<div class="instructions" onclick="this.classList.toggle('active')">
ℹ️ How to use
<p>
Add each task and choose the energy it requires.<br><br>

💤 Low = easy<br>
⚡ Medium = moderate<br>
🔥 High = harder<br><br>

Before deciding, set your current energy level.<br><br>

👉 Then follow it. No overthinking.
</p>
</div>

<input id="taskInput" placeholder="Add task">

<select id="energy">
<option value="low">💤 Low</option>
<option value="medium">⚡ Medium</option>
<option value="high">🔥 High</option>
</select>

<button onclick="addTask()">+ Add</button>

<!-- ✧ BALL -->
<div class="ball">
  <div class="inner">
    <div id="result">Ask me…</div>
  </div>
</div>

<button onclick="decide()">✨ Decide</button>

<!-- ✧ TASK DRAWER -->
<div class="drawer" id="drawer" onclick="toggleDrawer()">
<ul id="taskList"></ul>
</div>

<script>
let tasks = [];

function toggleDrawer(){
  document.getElementById("drawer").classList.toggle("open");
}

function addTask(){
  const text = document.getElementById("taskInput").value;
  const energy = document.getElementById("energy").value;

  if(text.trim()){
    tasks.push({text, energy});
    document.getElementById("taskInput").value="";
    render();
  }
}

function render(){
  const list = document.getElementById("taskList");
  list.innerHTML = "";

  tasks.forEach((t,i)=>{
    const li = document.createElement("li");
    li.innerHTML = `${t.text} <button onclick="deleteTask(${i})">✕</button>`;
    list.appendChild(li);
  });
}

function deleteTask(i){
  tasks.splice(i,1);
  render();
}

function decide(){
  if(!tasks.length) return alert("Add tasks");

  const selectedEnergy = document.getElementById("energy").value;

  let pool = [];

  if(selectedEnergy === "low"){
    pool = tasks.filter(t => t.energy === "low");
  }

  if(selectedEnergy === "medium"){
    pool = tasks.filter(t => t.energy !== "high");
  }

  if(selectedEnergy === "high"){
    pool = tasks;
  }

  if(pool.length === 0) pool = tasks;

  const choice = pool[Math.floor(Math.random()*pool.length)];
  document.getElementById("result").textContent = "👉 " + choice.text;
}

render();

/* ✧ SERVICE WORKER */
if ("serviceWorker" in navigator) {
  navigator.serviceWorker.register("service-worker.js");
}
</script>

</body>
</html>